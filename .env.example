# ========================================
# Database (Aiven PostgreSQL)
# ========================================
# Service URL จาก Aiven Console > PostgreSQL > Connection Information
# รูปแบบ: postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL="postgres://avnadmin:xxxxxxx@pg-xxxxx.aivencloud.com:12345/defaultdb?sslmode=require"

# ========================================
# Cron Secret (สำหรับ Vercel Cron)
# ========================================
# สร้างค่าสุ่มยาวๆ เช่น openssl rand -hex 32
CRON_SECRET="change-me-to-random-string"

# ========================================
# Email (เลือก provider เดียว — ใส่ค่าที่จะใช้)
# ========================================
EMAIL_PROVIDER="resend"   # resend | smtp

# กรณีใช้ Resend (resend.com)
RESEND_API_KEY=""
EMAIL_FROM="MEC Software Tracker <noreply@yourdomain.com>"

# กรณีใช้ SMTP (Gmail / Microsoft 365 / อื่นๆ)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# ผู้รับ Email แจ้งเตือน (คั่นด้วย comma)
ALERT_EMAILS="itadmin@mec-eng.co.th,patiwat.m@mec-eng.co.th"

# ========================================
# LINE Notifications
# ========================================
# LINE Messaging API (แนะนำ — LINE Notify จะหยุดให้บริการ 31 มี.ค. 2025)
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_TARGET_IDS=""   # User ID หรือ Group ID คั่นด้วย comma

# หรือถ้ายังใช้ LINE Notify ได้
LINE_NOTIFY_TOKEN=""

# ========================================
# Application
# ========================================
NEXT_PUBLIC_APP_NAME="MEC Software Tracker"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
